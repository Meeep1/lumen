# Server
NODE_ENV=development
PORT=3000

# Database - update the username if it doesn't match your Mac username
DATABASE_URL="postgresql://camdenheil@localhost:5432/lumen?schema=public"

# JWT Secrets - generate real ones with: openssl rand -base64 32
JWT_ACCESS_SECRET=GENERATE_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_SECRET_HERE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Admin panel outer gate — HTTP Basic Auth in front of /admin/ and every admin-only API route,
# on top of the existing per-account isAdmin JWT check. Required — the server fails closed
# (admin panel entirely unreachable) if these aren't set. Generate a password with:
# openssl rand -base64 18
ADMIN_BASIC_AUTH_USER=GENERATE_USER_HERE
ADMIN_BASIC_AUTH_PASSWORD=GENERATE_SECRET_HERE

# Redis
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000

# App settings
MIN_AGE=18
MAX_PHOTO_SIZE_MB=10
MAX_PHOTOS_PER_USER=6
IMAGE_MESSAGE_UNLOCK_THRESHOLD=3

# No AWS needed for local development. Photos are saved to backend/uploads/
# (see src/utils/storage.ts).
#
# Production-only, uncomment and fill in when deploying:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=lumen-photos
# S3_PRESIGNED_URL_EXPIRY=3600

# Push notifications — generate an APNs Auth Key at developer.apple.com/account/resources/authkeys
# (Team ID matches whatever code-signing team the app is registered under). Unset = push sends
# silently no-op (src/utils/apns.ts), nothing else breaks.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=./certs/AuthKey.p8
APNS_PRODUCTION=false

# Crash/error reporting — sentry.io DSN (free account, Node project). Unset = SDK no-ops (src/sentry.ts).
SENTRY_DSN=

# Email OTP (src/utils/email.ts) — any standard SMTP provider works. Unset = OTP codes print to
# the console instead of emailing (local dev fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Lumen
