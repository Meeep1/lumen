generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GenderIdentity {
  woman
  femboy
  trans_woman
  nonbinary_feminine
  other
}

enum SwipeDirection {
  like
  pass
  super_like
}

enum ModerationStatus {
  pending
  approved
  rejected
}

enum AppealStatus {
  none
  pending
  approved
  denied
}

enum VerificationStatus {
  none
  pending
  approved
  rejected
}

enum ReportStatus {
  pending
  reviewed
  actioned
}

enum ReportReason {
  harassment
  fake_profile
  misrepresenting_presentation
  inappropriate_content
  underage_suspicion
  other
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  phone    String @unique
  // Nullable because an Apple-only account has no password at all — Apple's own signed token
  // is the entire authentication, see routes/auth.ts's POST /auth/apple. Email/password login
  // simply isn't available for those accounts (checked at the /auth/login route).
  passwordHash String?
  // Apple's stable per-user identifier (the `sub` claim), set the first time someone either
  // signs up via Apple or links Apple to an existing email/password account.
  appleUserId String? @unique

  // First name only — no last name is collected, on purpose, matching every other dating app's
  // privacy norms (a full legal name isn't needed for anyone to swipe on or chat with you).
  // Collected once at signup, alongside dateOfBirth/genderIdentity below, and (like those two)
  // never wiped by resetTestAccount's onboarding-only reset.
  name String

  dateOfBirth             DateTime
  genderIdentity          GenderIdentity
  genderIdentityOther     String?
  femAttestationAccepted  Boolean   @default(false)
  femAttestationAcceptedAt DateTime?

  bio          String?
  pronouns     String?
  styleTags    String[] @default([])
  heightInches Int?
  jobTitle     String?
  school       String?

  prompt1Question String?
  prompt1Answer   String?
  prompt2Question String?
  prompt2Answer   String?
  prompt3Question String?
  prompt3Answer   String?

  isVerified               Boolean             @default(false)
  verificationPhotoUrl     String?
  verificationStatus       VerificationStatus  @default(none)
  // AdminUser's id — not a Prisma relation, same reasoning as Report.reviewedById below.
  verificationReviewedById String?
  verificationReviewedAt   DateTime?
  // A short-lived random pose id (see verification.ts's POSES list) the app fetches right before
  // opening the camera and requires the user to actually do in the selfie itself (see GET /pose
  // and POST /submit). A photo pulled from the camera roll or prepared in advance can't have
  // anticipated which pose would be asked for, so it's the cheap alternative to real liveness
  // detection for a still-manual review queue. Left in place after a submission (not cleared)
  // purely so the admin queue can keep showing "the pose that should be visible in this photo"
  // until the request is reviewed.
  verificationPose          String?
  verificationPoseExpiresAt DateTime?

  latitude    Float?
  longitude   Float?
  cityDisplay String?

  isActive     Boolean  @default(true)
  discoverable Boolean  @default(true)
  lastActiveAt DateTime @default(now())

  // Marks the single account handed to App Store review — every real email/password login
  // (see POST /auth/login) wipes this account's profile back to blank (no photos, no bio, no
  // location) so a reviewer always sees the full onboarding flow, then re-anchors the seed
  // profiles (`+seed@lumen.test`) near wherever the reviewer's device actually is once location
  // is set, so Discovery/Likes You are never empty regardless of where review happens.
  isTestAccount Boolean @default(false)

  // APNs device token, sent by the client after successful remote-notification registration
  // (see POST /profile/push-token). Only "ios" exists today, but the platform column is here
  // so a future Android client doesn't need a schema change to add itself.
  pushToken    String?
  pushPlatform String?

  notifyNewMatch   Boolean @default(true)
  notifyNewMessage Boolean @default(true)
  notifyNewLike    Boolean @default(true)

  // OTP now goes to email, not phone (cheaper than SMS and doesn't need a per-country carrier
  // integration) — phone is still collected at signup but no longer gates login.
  emailVerified Boolean   @default(false)
  otpCode       String?
  otpExpiresAt  DateTime?
  // A 6-digit code is only ~1M combinations — POST /auth/verify-otp's own rate limit (10/min) is
  // keyed per-IP (the default), so an attacker rotating source IPs faces no additional friction
  // guessing one specific victim's code within its 10-minute window. This counts failed guesses
  // *against this account* regardless of source IP, reset to 0 whenever a fresh OTP is issued
  // (signup or resend) — see verify-otp's own comment for the lockout threshold.
  otpAttempts   Int       @default(0)

  isSuspended      Boolean   @default(false)
  suspendedUntil   DateTime?
  suspensionReason String?

  createdAt DateTime @default(now())

  photos          Photo[]
  refreshTokens   RefreshToken[]

  swipesMade      Swipe[]  @relation("SwipesMade")
  swipesReceived  Swipe[]  @relation("SwipesReceived")

  matchesAsA Match[] @relation("MatchUserA")
  matchesAsB Match[] @relation("MatchUserB")

  messagesSent Message[]

  reportsMade     Report[] @relation("ReportsMade")
  reportsReceived Report[] @relation("ReportsReceived")

  blocksMade     Block[] @relation("BlocksMade")
  blocksReceived Block[] @relation("BlocksReceived")

  onboardingEvents OnboardingEvent[]

  feedbackSubmitted Feedback[]
}

model Photo {
  id               String            @id @default(uuid())
  userId           String
  url              String
  // A small resized copy generated alongside the original at upload time (see storage.ts's
  // uploadPhoto()) — every place that shows this photo small (Manage Photos' list row, the
  // admin queue) used to fetch the full original upload just to render a tiny box, the same
  // wasted-bandwidth problem moderateImage() already had to fix for its own tensor-building.
  // Nullable so photos uploaded before this existed just fall back to `url`.
  thumbnailUrl     String?
  order            Int
  moderationStatus ModerationStatus  @default(pending)
  // Human-readable classifier output at the time of the last moderation check (e.g. "Porn
  // (24%)") — stored so an admin reviewing the Photos queue can see *why* something was
  // flagged instead of just the resulting status. Recomputed whenever moderateImage() runs
  // (upload or rescan), not append-only history.
  moderationLabels String[]          @default([])
  createdAt        DateTime          @default(now())

  // Null when the current "rejected" status came from moderateImage() (upload or rescan) —
  // set to the admin's id only when a human explicitly rejected it via the admin site. Gates
  // appeal eligibility (see POST /profile/photos/:photoId/appeal): a model decision nobody's
  // looked at yet is worth a second look, but a photo a human already reviewed and rejected
  // isn't up for appeal — that review already was the second look.
  rejectedByAdminId String?

  // A rejected photo (auto or admin) is no longer deleted outright (see moderation.ts) —
  // kept specifically so an appeal has something to review. "none" until the owner appeals.
  appealStatus       AppealStatus @default(none)
  appealMessage      String?
  appealCreatedAt    DateTime?
  appealReviewedById String?
  appealReviewedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Catalog of every style tag ever used, upserted when a user adds a new tag
// to their profile. Powers autocomplete/browsing. The user's chosen tags
// themselves live on User.styleTags for fast reads (see app_spec.md Section 5).
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Swipe {
  id        String         @id @default(uuid())
  swiperId  String
  swipedId  String
  direction SwipeDirection
  createdAt DateTime       @default(now())

  // Hinge-style targeted likes: which specific photo or prompt (1 or 2) was liked, plus an
  // optional comment. Not a formal relation to Photo — a like is a record of what was liked
  // *at the time*, and shouldn't vanish or need cascade-handling if the photo is later deleted.
  likedPhotoId     String?
  likedPromptNumber Int?
  message          String?

  swiper User @relation("SwipesMade", fields: [swiperId], references: [id], onDelete: Cascade)
  swiped User @relation("SwipesReceived", fields: [swipedId], references: [id], onDelete: Cascade)

  @@unique([swiperId, swipedId])
}

model Match {
  id          String    @id @default(uuid())
  userAId     String
  userBId     String
  createdAt   DateTime  @default(now())
  unmatchedAt DateTime?
  unmatchedBy String?

  userA    User      @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User      @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userAId, userBId])
}

model Message {
  id        String    @id @default(uuid())
  matchId   String
  senderId  String
  content   String?
  imageUrl  String?
  createdAt DateTime  @default(now())
  readAt    DateTime?

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Report {
  id           String       @id @default(uuid())
  // Nullable with onDelete: SetNull, not Cascade — a report is moderation evidence, and either
  // party (reporter or reported) can self-service-delete their account at any time, including
  // after a report against them was already reviewed and actioned. Cascading would silently
  // erase that history the moment either account left, which is a worse outcome for a
  // safety-relevant record than for something like Feedback (same reasoning, same fix as
  // Feedback.userId got earlier).
  reporterId   String?
  reportedId   String?
  reason       ReportReason
  details      String?
  status       ReportStatus @default(pending)
  actionTaken  String?
  // AdminUser's id — not a Prisma relation, since admins live in a separate table now (see
  // AdminUser below) and this is only ever read back for audit purposes, never joined on.
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())

  reporter User? @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: SetNull)
  reported User? @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: SetNull)
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Staff accounts for the admin panel — deliberately its own table, not a flag on User. A
// dating-app account and an admin-panel account are different things with different lifecycles
// (a moderator shouldn't need a dating profile, and a suspended user account shouldn't be able
// to keep moderating), and keeping them separate means a leaked/compromised user JWT can never
// be used against admin routes even in principle — see middleware/adminAuth.ts's `type: 'admin'`
// claim check. No refresh-token table for these on purpose: it's a small internal team, so a
// longer-lived access token (12h, see routes/admin-auth.ts) that just requires re-login once a
// day is a fine tradeoff against building a second refresh-token flow for so few users.
model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String

  // Bypasses the permissions array entirely — always allowed everything, including managing
  // other admins. The very first admin (see scripts/create-admin.ts) is always one of these,
  // since nobody else exists yet to grant them anything.
  isSuperAdmin Boolean  @default(false)
  // Subset of ADMIN_PERMISSIONS (middleware/adminAuth.ts) — a non-super admin can only reach
  // the routes gated behind a permission that's in this array.
  permissions  String[] @default([])

  // Deactivating (rather than deleting) preserves the audit trail on whatever this admin
  // reviewed in the past (Report.reviewedById, User.verificationReviewedById, etc.) while
  // immediately cutting off login.
  isActive Boolean @default(true)

  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?
  // Which admin created this one — plain string, not a self-relation, for the same reason as
  // Report.reviewedById: audit trail only, never joined on, and shouldn't block deleting the
  // creator later.
  createdById String?
}

// Records sensitive admin reads — viewing a full profile, a chat transcript, or the user
// directory/search — that otherwise leave no trace at all (unlike an approve/reject decision,
// which already lands somewhere: Photo.rejectedByAdminId, Report.reviewedById, etc.). Exists so
// "who looked at my account, and when" has an actual answer.
model AdminAuditLog {
  id      String @id @default(uuid())
  // Plain strings, not relations — same reasoning as Report.reviewedById above: audit-only,
  // never joined on, shouldn't block deleting either side later. Email is denormalized at write
  // time so a log entry stays readable even after the admin account (or the viewed user) is gone.
  adminId    String
  adminEmail String
  action     String
  targetUserId String?
  // Free-form context specific to the action — e.g. the search query for a "viewed user list"
  // entry, or the other participant's id for a "viewed chat" entry.
  detail     String?
  createdAt  DateTime @default(now())
}

// Self-hosted onboarding funnel tracking — deliberately not a third-party analytics SDK
// (Amplitude/Mixpanel/etc.), since the Privacy Policy already states none exist. One row per
// "user reached this step" event (see OnboardingView.swift's `advance()`/`finish()`), so an
// admin can see where people actually drop off (GET /admin-tools/onboarding-funnel) without any
// user data ever leaving this server.
model OnboardingEvent {
  id        String   @id @default(uuid())
  userId    String
  step      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Free-text feedback from Settings — deliberately no status/reply workflow like Report has
// (pending/actioned, admin notes): this is a one-way "tell us something" box, read from the
// admin panel's Feedback tab, not a support ticket system with a response loop.
model Feedback {
  id        String   @id @default(uuid())
  // Nullable, with onDelete: SetNull rather than Cascade — feedback is meant to outlive the
  // account that sent it (an admin reading it later shouldn't lose it just because the sender
  // deleted their account since), unlike the rest of a deleted user's data (photos, matches,
  // messages) which genuinely should disappear with them.
  userId    String?
  message   String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
